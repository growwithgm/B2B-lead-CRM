# ── Supabase — Project Settings → API ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Klaviyo webhook ────────────────────────────────────────────────
# Any random secret string (e.g. 20+ random chars).
# Klaviyo must send this as ?secret=... or header x-webhook-secret
KLAVIYO_WEBHOOK_SECRET=

# ── WhatsApp (manual send) ─────────────────────────────────────────
# Your own WhatsApp app's send-message API. The adapter in lib/whatsapp.ts
# POSTs JSON with a Bearer token; adjust the body mapping there if your
# provider differs. Leave unset to disable sending (UI shows "not configured").
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_SENDER=

# ── Shopify Admin API (custom app) ─────────────────────────────────
# Custom-app Admin API access token. Required scopes:
#   read_customers, write_customers, read_orders
SHOPIFY_STORE_DOMAIN=         # e.g. my-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2024-10

# ── MCP server (mcp/) ──────────────────────────────────────────────
# Shared secret required to use the CRM MCP server (read + guarded write).
# The MCP server also reads SUPABASE_SERVICE_ROLE_KEY and the Supabase URL.
MCP_API_KEY=
