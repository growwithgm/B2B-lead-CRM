# ── Supabase — Project Settings → API ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Klaviyo webhook ────────────────────────────────────────────────
# Any random secret string (e.g. 20+ random chars).
# Klaviyo must send this as ?secret=... or header x-webhook-secret
KLAVIYO_WEBHOOK_SECRET=

# ── WhatsApp (manual send via wasify) ──────────────────────────────
# "Send WhatsApp" routes through the wasify app so threads/logs live there.
# lib/whatsapp.ts POSTs to {WHATSAPP_API_BASE_URL}/api/outbound/send with a
# Bearer token. Leave unset to disable sending (UI shows "not configured").
WHATSAPP_API_BASE_URL=https://wasify-one.vercel.app
# The WACRM_API_TOKEN bearer configured in the wasify Vercel project.
WHATSAPP_API_TOKEN=
# Optional; unused by wasify (it resolves the sender from its own config).
WHATSAPP_SENDER=

# ── Shopify Admin API (custom app) ─────────────────────────────────
# Custom-app Admin API access token. Required scopes:
#   read_customers, write_customers, read_orders, write_draft_orders, read_fulfillments
SHOPIFY_STORE_DOMAIN=         # e.g. my-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2024-10

# Shopify webhooks (orders/fulfilled + orders/paid → auto stage advance).
# HMAC verification secret for incoming webhooks (the value Shopify signs with).
SHOPIFY_WEBHOOK_SECRET=
# Where Shopify should POST webhooks (used by scripts/register-shopify-webhooks.ts).
SHOPIFY_WEBHOOK_CALLBACK_URL=https://b2-b-lead-crm.vercel.app/api/shopify/webhooks

# ── MCP server (mcp/) ──────────────────────────────────────────────
# Shared secret required to use the CRM MCP server (read + guarded write).
# The MCP server also reads SUPABASE_SERVICE_ROLE_KEY and the Supabase URL.
MCP_API_KEY=
